# =============================================================================
# Sanity CMS
# =============================================================================
# Studio, CLI, migration, and webhook setup scripts. These values are read on
# the server or from local scripts and are not exposed to the browser bundle.
SANITY_STUDIO_PROJECT_ID=your_sanity_project_id
SANITY_STUDIO_DATASET=production
SANITY_WRITE_TOKEN=your_sanity_write_token

# Frontend Sanity reader. Vite exposes VITE_* values in the public JS bundle,
# so only put public/read-only values here.
VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production

# =============================================================================
# Vercel Deploy Hook
# =============================================================================
# Used by:
#   npm run deploy:trigger
#   npm run deploy:webhook
#
# Create the hook in:
#   Vercel Dashboard -> gallery-site -> Settings -> Git -> Deploy Hooks
#
# Recommended values:
#   Name: Sanity CMS
#   Branch: master
#
# Vercel will give you a URL like:
#   https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy
#
# Treat this URL like a secret. Anyone with it can trigger a production rebuild.
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/your_hook_id/your_hook_secret

# =============================================================================
# Security checklist
# =============================================================================
# - Copy this file to .env.local and fill in real values there.
# - .env.local is git-ignored. Never commit it.
# - Never put SANITY_WRITE_TOKEN or VERCEL_DEPLOY_HOOK_URL in a VITE_* variable.
# - If a token or deploy hook leaks, revoke it and create a replacement.
