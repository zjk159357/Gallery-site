# =============================================================================
# Sanity CMS — required for content management & data sync scripts
# =============================================================================
# Studio / CLI / migration scripts — never exposed to the browser bundle
SANITY_STUDIO_PROJECT_ID=your_sanity_project_id
SANITY_STUDIO_DATASET=production
SANITY_WRITE_TOKEN=your_sanity_write_token

# Frontend — exposed to the browser via Vite (must be VITE_-prefixed, public)
# Use a READ-ONLY token if you have one; the project ID + dataset are public by
# default in Sanity, so VITE_SANITY_PROJECT_ID alone is safe.
VITE_SANITY_PROJECT_ID=your_sanity_project_id
VITE_SANITY_DATASET=production

# =============================================================================
# Where to get these values
# =============================================================================
# 1. Project ID + Dataset:
#    https://www.sanity.io/manage → select project → API → Project details
#
# 2. Write token (Editor permissions):
#    https://www.sanity.io/manage → API → Tokens → Add API token
#    Name: "gallery-site-local-migration"
#    Permissions: Editor
#    Copy the token immediately — Sanity will only show it once.
#
# 3. After creating a new token, REVOKE the old one in the same screen.
#    Rotate this token every time it has been shared with an external service
#    (cloud AI tools, shared CI runners, public chats, screenshots, etc.).
#
# =============================================================================
# Security checklist
# =============================================================================
# - .env.local is git-ignored (see .gitignore). Never commit it.
# - VITE_-prefixed variables are bundled into the public JS — do NOT put any
#   secret in a VITE_-prefixed variable. SANITY_WRITE_TOKEN must NEVER be
#   prefixed with VITE_.
# - The Sanity dataset has a public read policy by default; VITE_SANITY_*
#   values are safe to ship to the browser.
# - If a write token ever leaks, revoke it from sanity.io/manage immediately.
