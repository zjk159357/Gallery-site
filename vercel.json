{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/static/:path*",
      "destination": "/studio/static/:path*"
    },
    {
      "source": "/studio/((?!static/).*)",
      "destination": "/studio/index.html"
    },
    {
      "source": "/photos/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/stories/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|hero/|studio/|icons.svg|brand-mark.svg|favicon.svg|minimax-logo.png|archive-image.avif).*)",
      "destination": "/index.html"
    }
  ]
}
